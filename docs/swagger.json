{
  "openapi": "3.0.0",
  "info": {
    "title": "Logistics AI Optimization API",
    "version": "1.0.0",
    "description": "API para el análisis y optimización de reportes de telemetría de motores (DDEC, Nexiq) utilizando Inteligencia Artificial."
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Servidor de Desarrollo Local"
    }
  ],
  "paths": {
    "/api/upload": {
      "post": {
        "summary": "Sube un reporte PDF para extracción y guardado",
        "description": "Recibe un archivo PDF, valida su formato (solo PDFs < 5MB) y contenido, extrae el texto en memoria, y lo guarda en Supabase.",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "report": {
                    "type": "string",
                    "format": "binary",
                    "description": "Archivo PDF del reporte de motor"
                  },
                  "unitId": {
                    "type": "string",
                    "description": "Identificador de la unidad (Ej. 'T-10', '125'). Obligatorio, alfanumérico con al menos un número."
                  },
                  "mechanicNotes": {
                    "type": "string",
                    "description": "Notas adicionales del mecánico (Opcional)"
                  }
                },
                "required": ["report", "unitId"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Reporte procesado y guardado exitosamente" },
          "400": { "description": "Error de validación (archivo grande, formato incorrecto, o ID inválido)" },
          "500": { "description": "Error interno del servidor" }
        }
      }
    },
    "/api/reports": {
      "get": {
        "summary": "Obtiene todos los reportes almacenados",
        "responses": {
          "200": { "description": "Lista de reportes históricos" }
        }
      }
    },
    "/api/reports/{id}/analyze": {
      "post": {
        "summary": "Ejecuta el análisis de IA sobre un reporte",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": { "type": "string" },
            "description": "ID del reporte en la base de datos"
          }
        ],
        "responses": {
          "200": { "description": "Análisis JSON devuelto por Gemini/Claude" },
          "404": { "description": "Reporte no encontrado" }
        }
      }
    },
    "/api/chat": {
      "post": {
        "summary": "Chat interactivo con el Agente de IA",
        "description": "Permite realizar preguntas utilizando los últimos reportes generados como contexto.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "question": {
                    "type": "string",
                    "maxLength": 400,
                    "description": "Pregunta logística"
                  }
                },
                "required": ["question"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Respuesta generada por la IA" },
          "400": { "description": "Pregunta vacía o demasiado larga" }
        }
      }
    }
  }
}
